# Eat Leet Repeat — environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# The single tracked user's public LeetCode handle (server-only).
LEETCODE_USERNAME=your_leetcode_username

# Protects /api/poll. Must match the Authorization: Bearer <value> header set in
# cron-job.org. Use a random string of at least 16 characters (server-only).
CRON_SECRET=change_me_to_a_random_string_min_16_chars

# Supabase project URL (safe on client and server).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key — SERVER ONLY. Never ship to the client bundle.
# Used by the poller and server components for DB reads/writes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
