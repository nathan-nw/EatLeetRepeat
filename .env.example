# Eat Leet Repeat — environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#
# Multi-tenant: each user's LeetCode handle is stored in the DB
# (profiles.leetcode_username), set at onboarding — NOT an env var.

# Protects /api/poll. Must match the Authorization: Bearer <value> header set in
# cron-job.org. Use a random string of at least 16 characters (server-only).
CRON_SECRET=change_me_to_a_random_string_min_16_chars

# Supabase project URL (safe on client and server).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe on client). Used by Supabase Auth and
# RLS-scoped client reads. Find it in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service-role key — SERVER ONLY. Never ship to the client bundle.
# Bypasses RLS; used by the poller for DB writes and service-role reads.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
